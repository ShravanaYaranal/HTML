<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<style>
    h1{
     text-align: center;
    }
    body{
        background-color: lightgoldenrodyellow;
    }
    hr{
        height: 5px;
        background-color: black;
    }
    a:link{
      color: red;
    }
    a:visited{
        color: yellow;
    }
    a:hover{
        color: hotpink;
    }
    a:active{
        color: aqua;
    }
    body>div:last-child{
        background-color: blueviolet;
     }
    body>div:nth-child(7){
        background-color: chartreuse;
    }
    body>div:nth-child(7)>div:first-child>div
    {
        background-color: chocolate;
    }
    body>div:nth-child(5){
        background-color: crimson;
    }
</style>
<body>
    <h1>pseudo classes in CSS</h1>
    <hr>
    <a href="https://instagram.com">link</a>
    <hr>
    <div>come on</div>
    <div>lets have fun</div>
    <div>
        <div>guys when you done party last time
            <div>tell me</div>
        </div>
    </div>
    <div>we are attending marriage today</div>
    <div>she is so beautiful</div>
    <div>it went well</div>
    
</body>
</html>
